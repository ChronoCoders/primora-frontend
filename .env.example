# Backend origin for /api/* rewrites (dev only; prod uses Cloudflare routing)
BACKEND_ORIGIN=http://localhost:3000
NEXT_PUBLIC_WC_PROJECT_ID=your_walletconnect_project_id
NEXT_PUBLIC_CHAIN_ID=1

# Set true to target the local dual-Anvil pair (Ethereum id 1 @ :8545, Polygon
# id 137 @ :8546) instead of real RPCs. Leave unset/false in production.
NEXT_PUBLIC_USE_LOCAL_CHAINS=false

# Optional per-chain RPC overrides. When unset, the chain's default endpoint is
# used (local Anvil URLs in local mode, public RPCs in production).
# NEXT_PUBLIC_ETHEREUM_RPC_URL=
# NEXT_PUBLIC_POLYGON_RPC_URL=
